{
  "name": "aigenius-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "AIGenius Electron shell (Linux, macOS, Windows)",
  "author": "AIGenius",
  "homepage": "https://aigenius.chat",
  "main": "dist/main.js",
  "scripts": {
    "postinstall": "exit 0",
    "rebuild:better-sqlite3": "electron-rebuild -v 33.2.1 -f -m ../desktop-server -w better-sqlite3",
    "test": "cross-env NODE_ENV=test jest --config jest.config.cjs",
    "compile": "npm run sync-brand-icon && node scripts/compile-tsc.cjs",
    "build:server": "cd ../desktop-server && npm run build",
    "sync-brand-icon": "node scripts/sync-brand-icon.cjs",
    "prepare:resources": "node scripts/prepare-desktop-resources.cjs",
    "install:server-deps": "node scripts/install-server-deps-for-platform.cjs",
    "install:server-deps:win32": "node scripts/install-server-deps-for-platform.cjs win32 x64",
    "install:python-venv": "node scripts/prepare-python-venv.cjs",
    "prepackage": "node scripts/ensure-electron-dist.cjs && npm run compile && npm run build:server && cd ../frontend && npm run build:desktop && cd ../desktop && npm run install:server-deps && npm run install:python-venv && npm run prepare:resources",
    "prepackage:mac": "npm run prepackage",
    "prepackage:win": "npm run compile && npm run install:server-deps:win32 && npm run build:server && cd ../frontend && npm run build:desktop && cross-env AIGENIUS_PACKAGE_PLATFORM=win32 AIGENIUS_PACKAGE_ARCH=x64 npm run prepare:resources",
    "package": "electron-builder --linux deb flatpak",
    "package:deb": "electron-builder --linux deb",
    "package:deb:full": "npm run prepackage && electron-builder --linux deb",
    "package:flatpak": "electron-builder --linux flatpak",
    "package:mac": "electron-builder --mac",
    "package:mac:dir": "electron-builder --mac dir",
    "package:mac:full": "npm run prepackage:mac && electron-builder --mac",
    "package:win": "electron-builder --win",
    "package:win:dir": "electron-builder --win dir",
    "package:win:full": "npm run prepackage:win && electron-builder --win",
    "dev:frontend": "cd ../frontend && npm run dev",
    "dev:electron": "npm run compile && cross-env ELECTRON_DISABLE_SANDBOX=1 electron .",
    "dev:electron:debug": "npm run compile && cross-env ELECTRON_DISABLE_SANDBOX=1 AIGENIUS_DESKTOP_DEVTOOLS=1 electron .",
    "dev:quick": "npm run compile && npm run dev:electron",
    "download-models": "node scripts/download-search-models.cjs",
    "dev": "npm run rebuild:better-sqlite3 && npm run build:server && npm run compile && npm run dev:electron"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.14.0",
    "@types/sharp": "^0.31.1",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "electron": "33.2.1",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.3"
  },
  "build": {
    "appId": "chat.aigenius.desktop",
    "productName": "AIGenius",
    "electronVersion": "33.2.1",
    "electronDist": "../node_modules/electron/dist",
    "directories": {
      "output": "release"
    },
    "icon": "build/aigenius_icon_final.png",
    "files": [
      "dist/**/*",
      "package.json",
      "build/aigenius_icon_final.png"
    ],
    "asarUnpack": [
      "dist/local-index/**",
      "dist/search/**",
      "dist/models/**",
      "node_modules/better-sqlite3/**",
      "node_modules/onnxruntime-node/**",
      "node_modules/sharp/**"
    ],
    "extraResources": [
      {
        "from": "dist-resources/desktop-server",
        "to": "desktop-server"
      },
      {
        "from": "dist-resources/next-standalone",
        "to": "next-standalone"
      },
      {
        "from": "resources",
        "to": "aigenius-desktop-ui"
      },
      {
        "from": "dist-resources/python-venv",
        "to": "python-venv"
      }
    ],
    "linux": {
      "target": [
        "deb",
        "flatpak"
      ],
      "category": "Office",
      "maintainer": "AIGenius",
      "synopsis": "AIGenius desktop client"
    },
    "deb": {
      "afterInstall": "scripts/linux/deb-after-install.sh"
    },
    "flatpak": {
      "runtimeVersion": "24.08",
      "baseVersion": "24.08",
      "finishArgs": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--socket=pulseaudio",
        "--share=network",
        "--device=dri"
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "extendInfo": {
        "NSMicrophoneUsageDescription": "AIGenius uses the microphone for voice dictation and conversation."
      }
    },
    "dmg": {
      "sign": false
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
