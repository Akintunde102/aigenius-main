{
  "name": "aigenius-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "AIGenius Electron shell (Linux .deb + Flatpak)",
  "author": "AIGenius",
  "homepage": "https://aigenius.chat",
  "main": "dist/main.js",
  "scripts": {
    "postinstall": "exit 0",
    "rebuild:better-sqlite3": "electron-rebuild -v 33.2.1 -f -m ../desktop-server -w better-sqlite3",
    "test": "cross-env NODE_ENV=test jest --config jest.config.cjs",
    "test:tools:scenarios": "cross-env NODE_ENV=test jest --config jest.config.cjs --testPathPattern=local-desktop-tools\\.scenarios",
    "compile": "npm run sync-brand-icon && node scripts/compile-tsc.cjs",
    "ensure:server-deps": "node scripts/ensure-server-deps.cjs",
    "build:server": "npm run ensure:server-deps && cd ../desktop-server && npm run build",
    "sync-brand-icon": "node scripts/sync-brand-icon.cjs",
    "prepare:resources": "node scripts/prepare-desktop-resources.cjs",
    "prepackage": "npm run compile && npm run rebuild:better-sqlite3 && npm run build:server && cd ../frontend && npm run build:desktop && cd ../desktop && npm run prepare:resources",
    "package": "electron-builder --linux deb flatpak",
    "package:deb": "electron-builder --linux deb",
    "package:deb:full": "npm run prepackage && electron-builder --linux deb",
    "package:flatpak": "electron-builder --linux flatpak",
    "dev:frontend": "cd ../frontend && npm run dev",
    "dev:electron:only": "cross-env ELECTRON_DISABLE_SANDBOX=1 electron .",
    "dev:electron": "npm run compile && npm run dev:electron:only",
    "dev:electron:debug": "npm run compile && cross-env ELECTRON_DISABLE_SANDBOX=1 AIGENIUS_DESKTOP_DEVTOOLS=1 electron .",
    "dev:quick": "npm run compile && npm run dev:electron:only",
    "dev:tilt": "node scripts/dev-tilt.cjs",
    "download-models": "node scripts/download-search-models.cjs",
    "dev": "npm run rebuild:better-sqlite3 && npm run build:server && npm run compile && npm run dev:electron:only"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.14.0",
    "@types/sharp": "^0.31.1",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.3"
  },
  "build": {
    "appId": "chat.aigenius.desktop",
    "productName": "AIGenius",
    "directories": {
      "output": "release"
    },
    "icon": "build/aigenius_icon_final.png",
    "files": [
      "dist/**/*",
      "package.json",
      "build/aigenius_icon_final.png"
    ],
    "asarUnpack": [
      "dist/local-index/**",
      "dist/search/**",
      "dist/models/**",
      "node_modules/better-sqlite3/**",
      "node_modules/onnxruntime-node/**",
      "node_modules/sharp/**"
    ],
    "extraResources": [
      {
        "from": "dist-resources/desktop-server",
        "to": "desktop-server"
      },
      {
        "from": "dist-resources/next-standalone",
        "to": "next-standalone"
      },
      {
        "from": "resources",
        "to": "aigenius-desktop-ui"
      }
    ],
    "linux": {
      "target": [
        "deb",
        "flatpak"
      ],
      "category": "Office",
      "maintainer": "AIGenius",
      "synopsis": "AIGenius desktop client"
    },
    "deb": {
      "afterInstall": "scripts/linux/deb-after-install.sh"
    },
    "flatpak": {
      "runtimeVersion": "24.08",
      "baseVersion": "24.08",
      "finishArgs": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--socket=pulseaudio",
        "--share=network",
        "--device=dri"
      ]
    }
  }
}
