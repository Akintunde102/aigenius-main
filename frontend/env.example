# Authentication Configuration
# Set to 'true' to enable email-based authentication (currently disabled)
NEXT_PUBLIC_ENABLE_EMAIL_AUTH=false

# Set to 'false' to disable Google authentication (defaults to true)
NEXT_PUBLIC_ENABLE_GOOGLE_AUTH=true

# Set to 'true' to enable GitHub authentication (currently disabled)
NEXT_PUBLIC_ENABLE_GITHUB_AUTH=false

# Google OAuth Configuration
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# API Configuration
# Client-only (recommended for this repo): hosted API — no local NestJS/Postgres
NEXT_PUBLIC_NOBOX_API_ROOT_URL=https://ai-genius-copy-production.up.railway.app
NEXT_PUBLIC_API_URL=https://ai-genius-copy-production.up.railway.app
# Local full-stack (after `npm run backend:clone`): uncomment and use localhost instead
# NEXT_PUBLIC_NOBOX_API_ROOT_URL=http://localhost:8000
# NEXT_PUBLIC_API_URL=http://localhost:8000

# Workflows studio (optional): full URL to a background image (CSS background-image on the page shell)
# NEXT_PUBLIC_WORKFLOW_BG_IMAGE=https://example.com/workflows-bg.jpg

# Environment
NODE_ENV=development

# Public origin for Paystack return URLs and other browser redirects.
# - Web production: https://aigenius.chat
# - Desktop packaged build: set automatically by `npm run build:desktop` (http://127.0.0.1:3001)
# - Local web dev: omit (uses window.location.origin, e.g. http://localhost:3001)
# NEXT_PUBLIC_APP_ORIGIN=https://aigenius.chat

# =============================================================================
# PRODUCT FEATURE FLAGS (opt-in — unset/false = hidden in production)
# =============================================================================
# Frontend (browser): set to "true" to expose UI and routes locally
# NEXT_PUBLIC_ENABLE_AUDIO_CONVERSATION=true
# NEXT_PUBLIC_ENABLE_INTEGRATIONS=true
# NEXT_PUBLIC_ENABLE_WORKFLOWS=true
#
# Backend (API): must match frontend when enabling a feature
# ENABLE_INTEGRATIONS=true
# ENABLE_WORKFLOWS=true
#
# Audio conversation: frontend-only (phone icon + overlay). Mic dictation is always on.
# Workflows chat tool also requires ENABLE_WORKFLOWS=true (see WORKFLOW_MANAGEMENT_TOOL_ENABLED below).
