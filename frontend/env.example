# Authentication Configuration
# Set to 'true' to enable email-based authentication (currently disabled)
NEXT_PUBLIC_ENABLE_EMAIL_AUTH=false

# Set to 'false' to disable Google authentication (defaults to true)
NEXT_PUBLIC_ENABLE_GOOGLE_AUTH=true

# Set to 'true' to enable GitHub authentication (currently disabled)
NEXT_PUBLIC_ENABLE_GITHUB_AUTH=false

# Google OAuth Configuration
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# API Configuration
# Local full-stack (backend on :8000): http://localhost:8000
# Client-only team (no local backend): use your shared dev/staging API, e.g.:
# NEXT_PUBLIC_NOBOX_API_ROOT_URL=https://your-dev-api.example.com
NEXT_PUBLIC_NOBOX_API_ROOT_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Workflows studio (optional): full URL to a background image (CSS background-image on the page shell)
# NEXT_PUBLIC_WORKFLOW_BG_IMAGE=https://example.com/workflows-bg.jpg

# Environment
NODE_ENV=development
