# Picked up by the frontend service in docker-compose. Browser runs on the host, so
# the API is localhost (mapped from the backend container).
NODE_ENV=development
NEXT_PUBLIC_NOBOX_API_ROOT_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
CHOKIDAR_USEPOLLING=1
WATCHPACK_POLLING=true
