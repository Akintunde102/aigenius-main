# Environment Variables Example for AI Genius Platform

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Local Postgres: from repo root run `npm run db:up` (docker-compose.yml).
DATABASE_URL=postgresql://aigenius:aigenius@localhost:5432/ai_genius

# =============================================================================
# AUTHENTICATION & ENCRYPTION
# =============================================================================
# JWT Secret for authentication tokens
JWT_SECRET=your-jwt-secret-key-change-this-in-production

# Encryption key for sensitive data (must be 32-byte base64-encoded)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_SECRET_KEY=your-base64-encoded-32-byte-encryption-key

# =============================================================================
# GOOGLE OAUTH (for user login and Gmail integration)
# =============================================================================
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Google OAuth callback URL for user login
GOOGLE_CALLBACK_URL=http://localhost:3001/gateway/default/google/callback

# Gmail integration OAuth callback URL (can be same OAuth client as user login)
GMAIL_INTEGRATION_CALLBACK_URL=http://localhost:3001/gateway/default/integrations/gmail/callback

# LinkedIn integration (Sign In with LinkedIn using OpenID Connect — separate app from Google)
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_INTEGRATION_CALLBACK_URL=http://localhost:3001/gateway/default/integrations/linkedin/callback

# Optional: space- or comma-separated scopes (overrides defaults below). Example: openid profile email
# LINKEDIN_OAUTH_SCOPES=openid profile email

# Optional: include w_member_social automatically (requires "Share on LinkedIn" product in LinkedIn app)
# LINKEDIN_OAUTH_ENABLE_SHARING=true

# Default scopes are openid profile email only. Set true only if your LinkedIn app allows refresh tokens
# (otherwise LinkedIn returns invalid_scope_error). See .env.example LinkedIn notes at file bottom.
# LINKEDIN_OAUTH_OFFLINE_ACCESS=true

# Optional: appended to every LinkedIn /oauth/v2/authorization request (URL-encoded key=value pairs, &-separated).
# Example for mobile/native extended login per LinkedIn docs: enable_extended_login=true
# LINKEDIN_OAUTH_AUTHORIZATION_EXTRA=enable_extended_login=true

# When the app calls GET .../integrations/linkedin/connect?reauthorize=1, the backend adds OIDC `prompt` to
# encourage a fresh consent/login screen (LinkedIn may still SSO-skip; members can revoke the app under LinkedIn settings).
# Override the prompt value, or set to empty to disable: LINKEDIN_OAUTH_REAUTHORIZE_PROMPT=
# LINKEDIN_OAUTH_REAUTHORIZE_PROMPT=consent

# =============================================================================
# FRONTEND URL
# =============================================================================
# Frontend URL for OAuth redirects and CORS (Next dev in this repo: `next dev -p 3001`)
FRONTEND_URL=http://localhost:3001
DASHBOARD_URL=http://localhost:3001
# Optional: exact URL for `?token=` after Google/GitHub login (defaults to CLIENT_AUTH_PATH → FRONTEND_URL → DASHBOARD_URL → http://127.0.0.1:3001)
# CLIENT_AUTH_PATH=http://127.0.0.1:3001
# Optional: canonical browser origin for user-facing deep links (workflow agent summaries, etc.).
# In production use https://aigenius.chat if FRONTEND_URL/DASHBOARD_URL still point at localhost.
# PUBLIC_WEB_APP_URL=https://aigenius.chat
# Explicit workflow studio URL (highest priority for /workflow/:id links). Use for Electron + local Next, e.g.:
# WORKFLOW_STUDIO_BASE_URL=http://127.0.0.1:3001
# Backend: when NODE_ENV is not local/test, localhost workflow links are skipped unless:
# ALLOW_LOCALHOST_WORKFLOW_APP_URL=true

# Desktop tool delegate (streaming local_* tools to Electron):
# - Without Redis, delegate state is in-memory on ONE API process only. If chat/SSE and POST
#   /chat/desktop-tool-result hit different workers (load balancer, PM2 cluster), you get 404
#   "Unknown or expired delegate_id". Fix: run a single worker OR set shared Redis:
#     REDIS_URL=redis://127.0.0.1:6379
#   (or REDIS_HOST + REDIS_PORT). Same Redis family as BullMQ is fine.
# - DESKTOP_DELEGATE_USE_REDIS=false  # force in-process only (single API instance)
# - DESKTOP_DELEGATE_TIMEOUT_MS=120000  # 10s–900s; allow time for shell/patch approval UIs

# Next.js (see frontend/env.example): optional public vars such as
# NEXT_PUBLIC_WORKFLOW_BG_IMAGE — background image URL for the Workflows studio page.

# =============================================================================
# AI SERVICE PROVIDERS
# =============================================================================
# OpenRouter API key for AI model access (301+ models)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key
# Dev only: log full OpenRouter POST headers + body (exposes API key in logs).
# OPENROUTER_LOG_FULL_REQUEST=true
# Write each OpenRouter chat POST as pretty JSON files (url, headers, full body object). Directory is created if missing; relative paths are from the backend process cwd. Authorization is redacted unless:
# OPENROUTER_REQUEST_DUMP_INCLUDE_SECRETS=true
# OPENROUTER_REQUEST_DUMP_DIR=logs/openrouter-dumps

# OpenRouter model for `web_fetch` secondary pass (summarize / answer over fetched markdown). Default: openai/gpt-oss-20b.
# Cheaper option: openai/gpt-oss-20b:free (OpenRouter free tier; subject to rate limits).
# WEB_FETCH_PROMPT_MODEL=openai/gpt-oss-20b

# Alternative AI providers (optional)
OPENAI_API_KEY=sk-your-openai-api-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
GEMINI_API_KEY=your-gemini-api-key
CEREBRAS_API_KEY=your-cerebras-api-key
GROQ_API_KEY=gsk_your-groq-api-key

# =============================================================================
# WEB SEARCH & SCRAPING (Optional — chat tools for models that support tools)
# =============================================================================
# Serper: https://serper.dev — Google search API (set to enable serper_google_search)
# SERPER_API_KEY=
# Optional per-invocation billing in wallet/tool pricing (USD): SERPER_TOOL_USAGE_COST_USD=0.002

# Firecrawl: https://firecrawl.dev — SDK @mendable/firecrawl-js (entire firecrawl_* suite).
# The suite is gated in code (`FIRECRAWL_SUITE_AVAILABLE` in backend `firecrawl-tools.ts`); set that to true when resubscribing, then:
# FIRECRAWL_API_KEY=
# Optional: FIRECRAWL_TOOL_USAGE_COST_USD=0.005

# =============================================================================
# WORKFLOW MANAGEMENT TOOL (Optional — AI-powered workflow creation via chat)
# =============================================================================
# When enabled, the model can create, update, delete, list, and schedule workflows
# on the user's behalf using a natural language description.
# The inner model generates the workflow definition; the calling model presents a plan first.
#
# Enable/disable the suite (default: true)
# WORKFLOW_MANAGEMENT_TOOL_ENABLED=true
#
# Inner model used to generate workflow/schedule definitions (default: google/gemini-3-flash-preview)
# Must be a model ID resolvable via your configured AI provider (e.g. OpenRouter).
# WORKFLOW_TOOL_MODEL_ID=google/gemini-3-flash-preview
#
# The chat `workflow_agent` tool persists transcripts to Postgres table `agent_run`.
# After pulling changes that add this table, run migrations once:
#   cd backend && npm run db:migrate
# (uses PG_DATABASE_URL or DATABASE_URL — same as DATABASE_URL above.)
#
# Per-operation suite charges in USD (billed to user wallet; excludes upstream model token cost)
# WORKFLOW_TOOL_CREATE_COST_USD=0.02
# WORKFLOW_TOOL_UPDATE_COST_USD=0.02
# WORKFLOW_TOOL_SCHEDULE_COST_USD=0.01
# WORKFLOW_TOOL_DELETE_COST_USD=0.002
# WORKFLOW_TOOL_LIST_COST_USD=0.001

# =============================================================================
# PAYMENT PROCESSING (Optional)
# =============================================================================
PAYSTACK_SECRET_KEY=sk_test_your-paystack-secret-key
PAYSTACK_PUBLIC_KEY=pk_test_your-paystack-public-key
# Frontend Paystack inline popup (set in frontend/.env or root .env; NEXT_PUBLIC_ prefix required for browser)
NEXT_PUBLIC_PAYSTACK_KEY=pk_test_your-paystack-public-key

# =============================================================================
# EMAIL SERVICE (Optional)
# =============================================================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password
FROM_EMAIL=noreply@example.com

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
# Server port
PORT=3001

# Node environment
NODE_ENV=development

# API base path
API_PREFIX=api

# Rate limiting
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=100

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=info
# Optional: append the same structured log lines (plain text, no ANSI) to this file. Parent directory must exist (e.g. mkdir -p logs). Ignored paths: logs/, *.log in .gitignore.
# LOG_FILE_PATH=logs/backend.log

# Verbose chat completion trace: full system prompt (identity + user memory), message previews, tool names, each provider round. May contain PII — use only locally; unset in production.
# AIGENIUS_CHAT_COMPLETION_DEBUG=1

# =============================================================================
# SECURITY
# =============================================================================
# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Session secret
SESSION_SECRET=your-session-secret-key-change-this

# Docker Compose `sidecar` service (local search): Bearer token for /search/* on port 8001.
# For `docker compose up`, set this in a repo-root `.env` (compose reads it for ${...} substitution) or export it in the shell.
AIGENIUS_SECRET_TOKEN=your-sidecar-bearer-token-generate-a-long-random-value


# =============================================================================
# REDIS (Optional - for caching)
# =============================================================================
REDIS_URL=redis://localhost:6379
# BullMQ + desktop tool delegate (same as app.module BullModule.forRoot)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# =============================================================================
# S3 STORAGE (Optional - for file uploads)
# =============================================================================
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name

# =============================================================================
# MONITORING (Optional)
# =============================================================================
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# =============================================================================
# WALLET & BILLING
# =============================================================================
# E2E / Playwright / MCP browser: skip wallet checks when request header matches.
# Set the same value in frontend/.env as NEXT_PUBLIC_E2E_WALLET_BYPASS_SECRET. Never set in production.
# E2E_WALLET_BYPASS_SECRET=
# Optional: allow bypass when NODE_ENV=production (e.g. staging API only). Default: off in production.
# ALLOW_E2E_WALLET_BYPASS=true
# Frontend: wallet bypass only when NODE_ENV=test (Jest) or E2E_WALLET_BYPASS_TEST_CLIENT=1 with next dev (Playwright).

# Default wallet balance for new users (in USD)
DEFAULT_WALLET_BALANCE=10.00

# Minimum wallet balance before warning
MINIMUM_WALLET_BALANCE=1.00

# =============================================================================
# GMAIL INTEGRATION NOTES
# =============================================================================
# To enable Gmail integration:
# 1. Set up OAuth 2.0 credentials in Google Cloud Console
# 2. Enable Gmail API for your project
# 3. Add GMAIL_INTEGRATION_CALLBACK_URL to authorized redirect URIs
# 4. Configure GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET
# 5. Ensure ENCRYPTION_SECRET_KEY is set for secure token storage
#
# See docs/GMAIL_INTEGRATION_GUIDE.md for detailed setup instructions

# =============================================================================
# LINKEDIN INTEGRATION NOTES
# =============================================================================
# 1. Create an app at https://www.linkedin.com/developers/apps
# 2. Products tab: add "Sign In with LinkedIn using OpenID Connect" (required for openid / profile / email)
# 3. Auth tab: add authorized redirect URI exactly matching LINKEDIN_INTEGRATION_CALLBACK_URL
# 4. invalid_scope_error: usually missing OIDC product, wrong scopes, or requesting offline_access when
#    your app is not allowed to — leave LINKEDIN_OAUTH_OFFLINE_ACCESS unset (default) or set LINKEDIN_OAUTH_SCOPES explicitly
# 5. Posting requires "Share on LinkedIn" product + w_member_social scope
#    - set LINKEDIN_OAUTH_ENABLE_SHARING=true or include w_member_social in LINKEDIN_OAUTH_SCOPES
# 6. Set LINKEDIN_CLIENT_ID, LINKEDIN_CLIENT_SECRET, and LINKEDIN_INTEGRATION_CALLBACK_URL
